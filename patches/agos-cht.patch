+// 繁中融合 (非上游): 把已折行的 Big5 字串繪進字幕 sprite buffer
+void AGOSEngine::chtRenderStringCJK(uint vgaSpriteId, uint color, uint width, uint height, const char *txt) {
+	VgaPointersEntry *vpe = &_vgaBufferPointers[2];
+	if (vgaSpriteId >= 100) {
+		vgaSpriteId -= 100;
+		vpe++;
+	}
+	byte *base = vpe->vgaFile2;
+	byte *p = base + vgaSpriteId * 8;
+	WRITE_BE_UINT16(p + 4, height);
+	WRITE_BE_UINT16(p + 6, width);
+	byte *dst = base + readUint32Wrapper(p);
+
+	uint total = width * height;
+	if (total > 39000)
+		total = 39000;
+	memset(dst, 0, total);
+
+	// hires: sprite 留空(memset 已清 0),僅供 talk 計時/生命週期;
+	// 實際 crisp 字幕由 chtPrintScreenText 畫進 _scaleBuf 高解析疊層。
+	if (_chtHires && _scaleBuf)
+		return;
+
+	const int fw = _cht.fontW, fh = _cht.fontH, bpr = _cht.fontBpr;
+	int lineY = 0, curX = 0;
+	const byte *s = (const byte *)txt;
+	byte px = (byte)(color + 12);
+	while (*s) {
+		byte c = *s++;
+		if (c == '\n') { lineY += fh; curX = 0; continue; }
+		if (c == ' ') { curX += fw / 2; continue; }
+		if (chtIsBig5Lead(c) && *s) {
+			byte trail = *s++;
+			const byte *g = _cht.glyph(c, trail);
+			if (g && curX + fw <= (int)width) {
+				for (int row = 0; row < fh; row++) {
+					int yy = lineY + row;
+					if ((uint)(yy * (int)width + curX + fw) > total)
+						break;
+					byte *d = dst + yy * (int)width + curX;
+					const byte *gr = g + row * bpr;
+					for (int col = 0; col < fw; col++) {
+						if (gr[col >> 3] & (0x80 >> (col & 7)))
+							d[col] = px;
+					}
+				}
+			}
+			curX += fw;
+		} else {
+			curX += fw / 2;
+		}
+	}
+}
