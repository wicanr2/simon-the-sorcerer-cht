+					}
+				}
+			}
+		} else {
+			// 非 hires (320x200): 原地畫, 用取樣到的英文字色
+			int bx = x0 + (bw - textW) / 2; if (bx < x0) bx = x0;
+			int by = y0 + (bh - fh) / 2;    if (by < y0) by = y0;
+			for (int ci = 0; ci < nchars; ci++) {
+				const byte *g = _cht.glyph16((byte)label[ci * 2], (byte)label[ci * 2 + 1]);
+				if (!g) continue;
+				int gx = bx + ci * fw;
+				for (int row = 0; row < fh; row++) {
+					int yy = by + row;
+					if (yy < y0 || yy >= y0 + bh) continue;
+					const byte *gr = g + row * bpr;
+					byte *d = sp + yy * pitch + gx;
+					for (int col = 0; col < fw; col++) {
+						if (gx + col < x0 || gx + col >= x0 + bw) continue;
+						if (gr[col >> 3] & (0x80 >> (col & 7)))
+							d[col] = fg;
+					}
+				}
+			}
+		}
+	}
