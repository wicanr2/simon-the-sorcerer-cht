+// 繁中融合 (非上游): 把已折行的 Big5 字串繪進字幕 sprite buffer
+void AGOSEngine::chtRenderStringCJK(uint vgaSpriteId, uint color, uint width, uint height, const char *txt) {
+	VgaPointersEntry *vpe = &_vgaBufferPointers[2];
+	if (vgaSpriteId >= 100) {
+		vgaSpriteId -= 100;
+		vpe++;
+	}
+	byte *base = vpe->vgaFile2;
+	byte *p = base + vgaSpriteId * 8;
+	WRITE_BE_UINT16(p + 4, height);
+	WRITE_BE_UINT16(p + 6, width);
+	byte *dst = base + readUint32Wrapper(p);
+
+	uint total = width * height;
+	if (total > 39000)
+		total = 39000;
+	memset(dst, 0, total);
+
+	const int fw = _cht.fontW, fh = _cht.fontH, bpr = _cht.fontBpr;
+	int lineY = 0, curX = 0;
+	const byte *s = (const byte *)txt;
+	byte px = (byte)(color + 12);
+	while (*s) {
+		byte c = *s++;
+		if (c == '\n') { lineY += fh; curX = 0; continue; }
+		if (c == ' ') { curX += fw / 2; continue; }
+		if (chtIsBig5Lead(c) && *s) {
+			byte trail = *s++;
+			const byte *g = _cht.glyph(c, trail);
+			if (g && curX + fw <= (int)width) {
+				for (int row = 0; row < fh; row++) {
+					int yy = lineY + row;
+					if ((uint)(yy * (int)width + curX + fw) > total)
+						break;
+					byte *d = dst + yy * (int)width + curX;
+					const byte *gr = g + row * bpr;
+					for (int col = 0; col < fw; col++) {
+						if (gr[col >> 3] & (0x80 >> (col & 7)))
+							d[col] = px;
+					}
+				}
+			}
+			curX += fw;
+		} else {
+			curX += fw / 2;
+		}
+	}
+}
+
+// 繁中融合 (非上游): 把一個 Big5 字直接繪到 backend surface (視窗文字用)
+void AGOSEngine::chtDrawBig5OnSurface(WindowBlock *window, uint x, uint y, byte lead, byte trail) {
+	const byte *g = _cht.glyph(lead, trail);
+	if (!g)
+		return;
+	Graphics::Surface *screen = getBackendSurface();
+	byte *sp = (byte *)screen->getPixels();
+	uint pitch = screen->pitch;
+	int fw = _cht.fontW, fh = _cht.fontH, bpr = _cht.fontBpr;
+	byte tc = (byte)(window->textColor ? window->textColor : 15);
+	// 8px 列高容不下 24px, 往上抬讓字置中於文字行
+	int oy = (int)y - (fh - 8);
+	if (oy < 0)
+		oy = 0;
+	for (int row = 0; row < fh; row++) {
+		int yy = oy + row;
+		if (yy < 0 || yy >= screen->h)
+			continue;
+		const byte *gr = g + row * bpr;
+		byte *d = sp + yy * pitch + x;
+		for (int col = 0; col < fw; col++) {
+			if ((int)x + col >= screen->w)
+				break;
+			if (gr[col >> 3] & (0x80 >> (col & 7)))
+				d[col] = tc;
+		}
+	}
+	// getBackendSurface() 鎖了螢幕(_system->lockScreen()),必須配對解鎖,
+	// 比照 windowDrawChar 用 updateBackendSurface()。漏掉會讓螢幕永久鎖住:
+	// debug build 下一次 lockScreen 撞 !_screenIsLocked 斷言 abort;
+	// release build(NDEBUG,assert 被移除)則後續渲染錯位 → 全畫面文字糊成亂碼。
+	Common::Rect dirtyRect(x, oy, x + fw, oy + fh);
+	updateBackendSurface(&dirtyRect);
+}
