+// 繁中融合 (非上游): CJK 字幕折行 + 繪製; 命中回 true
+bool AGOSEngine::chtPrintScreenText(uint vgaSpriteId, uint color, const char *string, int16 x, int16 y, int16 width) {
+	if (!_chtActive || _chtSubLang != 1)
+		return false;
+	// 需含 Big5 (否則走原生 ASCII)
+	bool hasBig5 = false;
+	for (const byte *q = (const byte *)string; *q; q++)
+		if (chtIsBig5Lead(*q)) { hasBig5 = true; break; }
+	if (!hasBig5)
+		return false;
+
+	const int fw = _cht.fontW, fh = _cht.fontH;
+	int usableW = width;
+	if (usableW < fw * 4)
+		usableW = 288;
+	if (usableW > 312)
+		usableW = 312;
+	int maxCells = usableW / fw;
+	if (maxCells < 1)
+		maxCells = 1;
+
+	Common::String out;
+	int cells = 0, lines = 1;
+	const byte *s = (const byte *)string;
+	while (*s) {
+		byte c = *s;
+		if (chtIsBig5Lead(c) && s[1]) {
+			if (cells >= maxCells) { out += '\n'; cells = 0; lines++; }
+			out += (char)s[0]; out += (char)s[1]; s += 2; cells++;
+		} else {
+			if (cells * 2 >= maxCells * 2) { /* half cell */ }
+			if (cells >= maxCells) { out += '\n'; cells = 0; lines++; }
+			out += (char)c; s++;
+			// 半形前進半格
+		}
+	}
+	if (lines > 5) lines = 5;
+
+	int stringLength = strlen(string);
+	int talkDelay = (stringLength + 3) / 3;
+	if (_variableArray[86] == 0) talkDelay /= 2;
+	if (_variableArray[86] == 2) talkDelay *= 2;
+	_variableArray[85] = talkDelay * 5;
+
+	if (getGameType() == GType_SIMON1)
+		stopAnimate(vgaSpriteId + 199);
+
+	uint rcolor = color * 3 + 192;
+	chtRenderStringCJK(vgaSpriteId, rcolor, usableW, lines * fh, out.c_str());
+
+	uint16 windowNum = (!getBitFlag(133)) ? 3 : 4;
+	if (getGameType() == GType_SIMON1 && (getFeatures() & GF_DEMO))
+		windowNum = 4;
+	int16 rx = x / 8;
+	int16 ry = y;
+	if (ry < 2) ry = 2;
+	if (getGameType() == GType_SIMON1) {
+		uint16 id = 199 + vgaSpriteId;
+		animate(windowNum, id / 100, id, rx, ry, 12);
+
+		// hires: 字幕 crisp 畫進 _scaleBuf 高解析疊層(24px 原生, 相對變小不擠);
+		// sprite 本身留空只保 talk 計時/生命週期。displayScreen 偵測 sprite 消失時清除。
+		if (_chtHires && _scaleBuf) {
+			chtClearSubtitle();
+			int fw2 = _cht.fontW, fh2 = _cht.fontH, bpr2 = _cht.fontBpr;
+			// issue #4:亮度守門(只救暗到讀不到的)+ 1px 描邊(壓在花紋美術上也有輪廓)
+			byte px = chtReadableColor((byte)(rcolor + 12));
+			byte ol = chtOutlineColor();
+			// compact map: sprite 落在 (rx cell = x/8) → 像素 x ≈ rx*8, hires *2 = rx*16;垂直 ry*2。
+			int baseX = rx * 16, baseY = ry * 2;
+			byte *hp = (byte *)_scaleBuf->getPixels();
+			uint hpitch = _scaleBuf->pitch;
+			int curX = 0, lineY = 0, maxX = 0;
+			const byte *t = (const byte *)out.c_str();
+			while (*t) {
+				byte c = *t++;
+				if (c == '\n') { lineY += fh2; curX = 0; continue; }
+				if (c == ' ') { curX += fw2 / 2; continue; }
+				if (chtIsBig5Lead(c) && *t) {
+					byte trail = *t++;
+					const byte *g = _cht.glyph(c, trail);
+					if (g) {
+						// pass 1: 描邊(每個字元筆畫像素的 8 鄰域塗最暗色)→ 任意背景都有輪廓
+						// pass 2: 蓋上本體字色。兩趟才不會被相鄰筆畫的描邊吃掉。
+						for (int pass = 0; pass < 2; pass++) {
+							for (int row = 0; row < fh2; row++) {
+								const byte *gr = g + row * bpr2;
+								for (int col = 0; col < fw2; col++) {
+									if (!(gr[col >> 3] & (0x80 >> (col & 7))))
+										continue;
+									int xx = baseX + curX + col, yy = baseY + lineY + row;
+									if (pass == 0) {
+										for (int dy = -1; dy <= 1; dy++)
+											for (int dx = -1; dx <= 1; dx++) {
+												int ox = xx + dx, oy2 = yy + dy;
+												if (ox < 0 || ox >= _scaleBuf->w || oy2 < 0 || oy2 >= _scaleBuf->h)
+													continue;
+												hp[oy2 * hpitch + ox] = ol;
+											}
+									} else {
+										if (xx < 0 || xx >= _scaleBuf->w || yy < 0 || yy >= _scaleBuf->h)
+											continue;
+										hp[yy * hpitch + xx] = px;
+									}
+								}
+							}
+						}
+					}
+					curX += fw2;
+					if (curX > maxX) maxX = curX;
+				} else {
+					curX += fw2 / 2;
+					if (curX > maxX) maxX = curX;
+				}
+			}
+			// +2 邊界:描邊會超出字框 1px,清除範圍要含進去,否則殘留一圈黑邊
+			_chtSubRect = Common::Rect(baseX - 2, baseY - 2, baseX + maxX + 2, baseY + lineY + fh2 + 2);
+			_chtSubId = id;
+			_chtSubZone = id / 100;
+			updateBackendSurface(nullptr);
+		}
+	}
+	return true;
+}
+
+// 繁中融合 (非上游): 調色盤亮度守門 —— 只救「暗到讀不到」的字,其餘保留原本的說話者配色。
+// 玩家回報(issue #4):某些說話者色算出的索引落在暗色,壓在深色美術上讀不到;但無差別塗白
+// 會讓各角色字幕全變白、失去辨識 → 只在太暗時換成「色相最接近且夠亮」的既有調色盤索引。
+// 判準:BT.601 luma(_currentPalette 為 0–255),Y < 90 視為太暗(字幕疊在任意美術上,門檻放寬)。
+// 成本:每句字幕算一次(非逐字/逐像素),256 掃描可忽略。
+#define CHT_LUMA(p, i) ((299 * (p)[(i) * 3] + 587 * (p)[(i) * 3 + 1] + 114 * (p)[(i) * 3 + 2]) / 1000)
+
+static int chtHueOf(const byte *p, int i) {
+	int r = p[i * 3], g = p[i * 3 + 1], b = p[i * 3 + 2];
+	int mx = MAX(r, MAX(g, b)), mn = MIN(r, MIN(g, b));
+	if (mx == mn)
+		return -1;                       // 近灰:色相無意義
+	int d = mx - mn;
+	if (mx == r)  return (60 * (g - b) / d + 360) % 360;
+	if (mx == g)  return  60 * (b - r) / d + 120;
+	return               60 * (r - g) / d + 240;
+}
+
+byte AGOSEngine::chtReadableColor(byte idx) {
+	const byte *p = _currentPalette;
+	if (CHT_LUMA(p, idx) >= 90)
+		return idx;                      // 夠亮 → 原色不動(保留各說話者配色)
+
+	int srcH = chtHueOf(p, idx);
+	int best = -1, bestScore = 1 << 30, brightest = -1, brightestY = -1;
+	for (int i = 1; i < 256; i++) {      // 跳過 0(_scaleBuf 疊層的透明哨兵)
+		int y = CHT_LUMA(p, i);
+		if (y > brightestY) { brightestY = y; brightest = i; }
+		if (y < 90)
+			continue;
+		int h = chtHueOf(p, i);
+		int score;
+		if (srcH < 0 || h < 0) {
+			score = 400 - y;             // 來源近灰 → 挑最亮的中性色
+		} else {
+			int dh = ABS(h - srcH);
+			if (dh > 180) dh = 360 - dh;
+			score = dh;                  // 色相最接近優先(保留角色識別)
+		}
+		if (score < bestScore) { bestScore = score; best = i; }
+	}
+	if (best > 0)
+		return (byte)best;
+	return (byte)(brightest > 0 ? brightest : 15);   // 整個調色盤都暗(夜晚/地牢)才退回最亮
+}
+
+// 描邊色:調色盤中最暗的「非 0」索引。0 在 _scaleBuf 合成規則(*dst = v1 ? v1 : v0)是
+// 「未寫入/透明」哨兵,拿來描邊會被當成沒畫 → 必須另挑一個視覺夠黑的既有索引。
+byte AGOSEngine::chtOutlineColor() {
+	const byte *p = _currentPalette;
+	int best = 1, bestY = 1 << 30;
+	for (int i = 1; i < 256; i++) {
+		int y = CHT_LUMA(p, i);
+		if (y < bestY) { bestY = y; best = i; }
+	}
+	return (byte)best;
+}
