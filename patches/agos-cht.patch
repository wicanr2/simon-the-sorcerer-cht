+// 非上游: 在底部 12 格指令面板疊上 16x16 中文 verb 標籤。
+// 面板文字是烘進介面圖的英文像素(不走引擎文字系統),故以覆蓋層處理:
+// 對每個 verb box(101..112)取樣底色+英文字色 → 清掉英文區 → 用取樣到的字色畫中文。
+// 每格取樣 = hover 反白時取到反白色, 中文自動跟著高亮。畫在 displayScreen 已鎖的 surface。
+void AGOSEngine::chtDrawVerbPanel(Graphics::Surface *screen) {
+	if (!_chtActive || _chtSubLang != 1 || getGameType() != GType_SIMON1 || !_cht.font16 || !screen)
+		return;
+	const int fw = _cht.fontW16, fh = _cht.fontH16, bpr = _cht.fontBpr16;
+	byte *sp = (byte *)screen->getPixels();       // hires 時 = _backBuf(320x200 邏輯層)
+	const uint pitch = screen->pitch;
+
+	// hires: 找調色盤中「最亮(最白)」的 index 當面板字色(高對比);中文畫進 _scaleBuf 高解析疊層
+	const bool hires = _chtHires && _scaleBuf;
+	int whiteIdx = -1, whiteBright = -1;
+	byte *hp = nullptr; uint hpitch = 0;
+	if (hires) {
+		for (int i = 1; i < 256; i++) {   // 跳過 0(透明/黑)
+			int s = _currentPalette[i * 3] + _currentPalette[i * 3 + 1] + _currentPalette[i * 3 + 2];
+			if (s > whiteBright) { whiteBright = s; whiteIdx = i; }
+		}
+		hp = (byte *)_scaleBuf->getPixels();
+		hpitch = _scaleBuf->pitch;
+	}
+	const bool haveWhite = (whiteBright >= 500 && whiteIdx > 0);   // 8-bit 調色盤夠亮才算白
+
+	for (uint id = 101; id <= 112; id++) {
+		HitArea *ha = findBox(id);
+		if (!ha || (ha->flags & kBFBoxDead) || ha->width == 0 || ha->height == 0)
+			continue;
+		int x0 = ha->x, y0 = ha->y, bw = ha->width, bh = ha->height;
+		if (x0 < 0 || y0 < 0 || x0 + bw > screen->w || y0 + bh > screen->h)
+			continue;
+		// 用直方圖取底色(最多數)+ 英文字色(第二多);比角落取樣穩(不會取到文字/邊框)
+		int hist[256]; memset(hist, 0, sizeof(hist));
+		for (int yy = y0; yy < y0 + bh; yy++)
+			for (int xx = x0; xx < x0 + bw; xx++)
+				hist[sp[yy * pitch + xx]]++;
+		int bgI = 0, bgC = -1;
+		for (int i = 0; i < 256; i++) if (hist[i] > bgC) { bgC = hist[i]; bgI = i; }
+		int fgI = -1, fgC = 0;
+		for (int i = 0; i < 256; i++) if (i != bgI && hist[i] > fgC) { fgC = hist[i]; fgI = i; }
+		if (fgI < 0)
+			continue;   // 只有底色(空格)→ 不動
+		byte bg = (byte)bgI, fg = (byte)fgI;
+		// 抹掉 _backBuf 的英文(填底色)
+		for (int yy = y0; yy < y0 + bh; yy++)
+			memset(sp + yy * pitch + x0, bg, bw);
+
+		const char *label = cht_verb_names[id - 101];
+		int nchars = (int)strlen(label) / 2;
+		int textW = nchars * fw;
+
+		if (hires) {
+			// 清 _scaleBuf 對應 2x 區(0=透明→顯示放大後的乾淨底色), 置中畫清晰白字
+			int hx = x0 * 2, hy = y0 * 2, hw = bw * 2, hh = bh * 2;
+			for (int yy = 0; yy < hh; yy++)
+				memset(hp + (hy + yy) * hpitch + hx, 0, hw);
+			int bx = hx + (hw - textW) / 2; if (bx < hx) bx = hx;
+			int by = hy + (hh - fh) / 2;    if (by < hy) by = hy;
+			for (int ci = 0; ci < nchars; ci++) {
+				const byte *g = _cht.glyph16((byte)label[ci * 2], (byte)label[ci * 2 + 1]);
+				if (!g) continue;
+				int gx = bx + ci * fw;
+				for (int row = 0; row < fh; row++) {
+					int yy = by + row;
+					if (yy < hy || yy >= hy + hh) continue;
+					const byte *gr = g + row * bpr;
+					byte *d = hp + yy * hpitch + gx;
+					byte pc = haveWhite ? (byte)whiteIdx : fg;   // 有白就用白, 否則退回英文字色
+					for (int col = 0; col < fw; col++) {
+						if (gx + col < hx || gx + col >= hx + hw) continue;
+						if (gr[col >> 3] & (0x80 >> (col & 7)))
+							d[col] = pc;
+					}
+				}
+			}
+		} else {
+			// 非 hires (320x200): 原地畫, 用取樣到的英文字色
+			int bx = x0 + (bw - textW) / 2; if (bx < x0) bx = x0;
+			int by = y0 + (bh - fh) / 2;    if (by < y0) by = y0;
+			for (int ci = 0; ci < nchars; ci++) {
+				const byte *g = _cht.glyph16((byte)label[ci * 2], (byte)label[ci * 2 + 1]);
+				if (!g) continue;
+				int gx = bx + ci * fw;
+				for (int row = 0; row < fh; row++) {
+					int yy = by + row;
+					if (yy < y0 || yy >= y0 + bh) continue;
+					const byte *gr = g + row * bpr;
+					byte *d = sp + yy * pitch + gx;
+					for (int col = 0; col < fw; col++) {
+						if (gx + col < x0 || gx + col >= x0 + bw) continue;
+						if (gr[col >> 3] & (0x80 >> (col & 7)))
+							d[col] = fg;
+					}
+				}
+			}
+		}
+	}
+}
