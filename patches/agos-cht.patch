+// 繁中融合 (非上游): 把一個 Big5 字直接繪到 backend surface (視窗文字用)
+void AGOSEngine::chtDrawBig5OnSurface(WindowBlock *window, uint x, uint y, byte lead, byte trail) {
+	const byte *g = _cht.glyph(lead, trail);
+	if (!g)
+		return;
+
+	// hires: 視窗文字(懸停動作句/物件名/對話選項)畫進 _scaleBuf 高解析疊層。
+	// [重要] 用 16px 字型 + 乾淨 2x 映射:引擎的視窗是為 8px ASCII 行設計的,textRow 每行只前進 8px。
+	// 若用 24px 字(舊作法),多行視窗(對話選項)每行會疊掉 16px → 糊成一團(issue #4)。
+	// 16px 字在 _scaleBuf 剛好 = 8 邏輯px = 引擎一個行/列 → 行列自然對齊,不重疊。
+	if (_chtHires && _scaleBuf) {
+		const byte *g16 = _cht.glyph16(lead, trail);
+		if (!g16)
+			return;
+		int fw = _cht.fontW16, fh = _cht.fontH16, bpr = _cht.fontBpr16;
+		// issue #4:視窗文字(懸停物件名/對話選項)也可能壓在美術上 → 同樣套亮度守門,
+		// 只救暗到讀不到的,其餘保留原本 textColor(對話選項的編號色/選中色分離才不會被吃掉)。
+		byte tc = chtReadableColor((byte)(window->textColor ? window->textColor : 15));
+		int bx = (int)x * 2;                  // x/y 是邏輯像素 → 乾淨 2x 進 _scaleBuf
+		int by = (int)y * 2;
+		byte *hp = (byte *)_scaleBuf->getPixels();
+		uint hpitch = _scaleBuf->pitch;
+		for (int row = 0; row < fh; row++) {
+			int yy = by + row;
+			if (yy < 0 || yy >= _scaleBuf->h) continue;
+			const byte *gr = g16 + row * bpr;
+			byte *d = hp + yy * hpitch + bx;
+			for (int col = 0; col < fw; col++) {
+				if (bx + col < 0 || bx + col >= _scaleBuf->w) break;
+				if (gr[col >> 3] & (0x80 >> (col & 7)))
+					d[col] = tc;
+			}
+		}
+		updateBackendSurface(nullptr);   // 全螢幕合成(_scaleBuf 疊層蓋上放大底圖)
+		return;
+	}
+
+	Graphics::Surface *screen = getBackendSurface();
+	byte *sp = (byte *)screen->getPixels();
+	uint pitch = screen->pitch;
+	int fw = _cht.fontW, fh = _cht.fontH, bpr = _cht.fontBpr;
+	byte tc = (byte)(window->textColor ? window->textColor : 15);
+	// 8px 列高容不下 24px, 往上抬讓字置中於文字行
+	int oy = (int)y - (fh - 8);
+	if (oy < 0)
+		oy = 0;
+	for (int row = 0; row < fh; row++) {
+		int yy = oy + row;
+		if (yy < 0 || yy >= screen->h)
+			continue;
+		const byte *gr = g + row * bpr;
+		byte *d = sp + yy * pitch + x;
+		for (int col = 0; col < fw; col++) {
+			if ((int)x + col >= screen->w)
+				break;
+			if (gr[col >> 3] & (0x80 >> (col & 7)))
+				d[col] = tc;
+		}
+	}
+	// getBackendSurface() 鎖了螢幕(_system->lockScreen()),必須配對解鎖,
+	// 比照 windowDrawChar 用 updateBackendSurface()。漏掉會讓螢幕永久鎖住:
+	// debug build 下一次 lockScreen 撞 !_screenIsLocked 斷言 abort;
+	// release build(NDEBUG,assert 被移除)則後續渲染錯位 → 全畫面文字糊成亂碼。
+	Common::Rect dirtyRect(x, oy, x + fw, oy + fh);
+	updateBackendSurface(&dirtyRect);
+}
