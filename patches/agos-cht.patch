+// 非上游: 在底部 12 格指令面板疊上 16x16 中文 verb 標籤。
+// 面板文字是烘進介面圖的英文像素(不走引擎文字系統),故以覆蓋層處理:
+// 對每個 verb box(101..112)取樣底色+英文字色 → 清掉英文區 → 用取樣到的字色畫中文。
+// 每格取樣 = hover 反白時取到反白色, 中文自動跟著高亮。畫在 displayScreen 已鎖的 surface。
+void AGOSEngine::chtDrawVerbPanel(Graphics::Surface *screen) {
+	if (!_chtActive || _chtSubLang != 1 || getGameType() != GType_SIMON1 || !_cht.font16 || !screen)
+		return;
+	const int fw = _cht.fontW16, fh = _cht.fontH16, bpr = _cht.fontBpr16;
+	byte *sp = (byte *)screen->getPixels();       // hires 時 = _backBuf(320x200 邏輯層)
+	const uint pitch = screen->pitch;
