+// 繁中融合 (非上游): 清掉 _scaleBuf 上的字幕 crisp 疊層(hires)
+void AGOSEngine::chtClearSubtitle() {
+	if (!_chtHires || !_scaleBuf || _chtSubId == 0)
+		return;
+	int x0 = _chtSubRect.left, y0 = _chtSubRect.top;
+	int w = _chtSubRect.width(), h = _chtSubRect.height();
+	if (x0 < 0) { w += x0; x0 = 0; }
+	if (y0 < 0) { h += y0; y0 = 0; }
+	if (x0 + w > _scaleBuf->w) w = _scaleBuf->w - x0;
+	if (y0 + h > _scaleBuf->h) h = _scaleBuf->h - y0;
+	if (w > 0 && h > 0) {
+		byte *hp = (byte *)_scaleBuf->getPixels();
+		for (int yy = 0; yy < h; yy++)
+			memset(hp + (y0 + yy) * _scaleBuf->pitch + x0, 0, w);
+	}
+	_chtSubId = 0;
+	updateBackendSurface(nullptr);
+}
